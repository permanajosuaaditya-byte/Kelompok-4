body{
    font-family: Arial, sans-serif;
    background-color: #f4f4f4;
    text-align: center;
}

h1{
    color: #2c3e50;
}

.menu{
    margin: 20px;
}

.menu a{
    text-decoration: none;
    padding: 10px 20px;
    background-color: #3498db;
    color: white;
    margin: 5px;
    border-radius: 5px;
}

.card{
    background: white;
    width: 300px;
    margin: 15px auto;
    padding: 15px;
    border-radius: 10px;
    box-shadow: 0px 0px 5px gray;
}

table{
    margin: auto;
    border-collapse: collapse;
    width: 70%;
}

th, td{
    padding: 10px;
}

th{
    background-color: #3498db;
    color: white;
}
